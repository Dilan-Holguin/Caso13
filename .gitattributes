# Default: let Git handle text files
* text=auto

# Enforce LF for shell, YAML and CI workflow files
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# PowerShell scripts keep CRLF on Windows
*.ps1  text eol=crlf

# Java and XML files: use LF
*.java text eol=lf
*.xml  text eol=lf
pom.xml text eol=lf

# Ensure scripts folder uses LF for portability
scripts/** text eol=lf

# Node/Maven/Gradle metadata (if present) should be normalized
*.properties text eol=lf
*.md text eol=lf
/mvnw text eol=lf
*.cmd text eol=crlf
