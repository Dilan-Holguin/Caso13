# ============================================================
# Variables de entorno para Domésticas API
# Copia este archivo como .env y ajusta los valores
# ============================================================

# Base de datos PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/domesticas_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT - genera un secreto fuerte: openssl rand -base64 64
APP_JWT_SECRET=cambia-este-secreto-por-uno-fuerte-de-al-menos-256-bits
APP_JWT_EXPIRATION=86400000

# Email (Mailtrap para desarrollo)
SPRING_MAIL_HOST=sandbox.smtp.mailtrap.io
SPRING_MAIL_PORT=2525
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# Frontend URL
APP_FRONTEND_URL=http://localhost:3000

# CORS allowed origins (separados por coma)
APP_CORS_ORIGINS=https://project-tdwx8.vercel.app,http://localhost:3000
