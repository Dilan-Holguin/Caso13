{
  "info": {
    "_postman_id": "4fdd4e9b-6f5d-4df4-8cda-4458ef2f0f49",
    "name": "Sprint1 - Auth Test Cases (CP-001 a CP-013)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion para ejecutar los casos de prueba del Sprint 1 de autenticacion y acceso.\n\nOrden sugerido:\n1) CP-001\n2) CP-004-SETUP y CP-004\n3) CP-006\n4) Resto de casos negativos.\n\nVariables importantes:\n- baseUrl: URL base del backend\n- validName, validEmail, validPassword: datos para registro/login exitoso\n- duplicateEmail: correo para probar duplicados\n- unregisteredEmail: correo no registrado\n\nNota: forgot-password (CP-010 y CP-011) devuelve 200 en ambos escenarios por seguridad."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "validName", "value": "Usuario QA" },
    { "key": "validEmail", "value": "qa.valid.{{$timestamp}}@mail.com" },
    { "key": "validPassword", "value": "Password123" },
    { "key": "duplicateEmail", "value": "qa.duplicate@mail.com" },
    { "key": "unregisteredEmail", "value": "qa.unregistered@mail.com" },
    { "key": "invalidEmail", "value": "usuariohogar.com" },
    { "key": "weakPassword", "value": "1234567" },
    { "key": "minPassword", "value": "12345678" },
    { "key": "invalidPassword", "value": "WrongPass123" },
    { "key": "savedToken", "value": "" },
    { "key": "resetToken", "value": "" }
  ],
  "item": [
    {
      "name": "HU 3 - Registro de usuario",
      "item": [
        {
          "name": "CP-001 Registro exitoso con datos validos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Retorna token y email', function () {",
                  "  pm.expect(json).to.have.property('token');",
                  "  pm.expect(json).to.have.property('email');",
                  "});",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('savedToken', json.token);",
                  "}",
                  "if (json.email) {",
                  "  pm.collectionVariables.set('validEmail', json.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"{{validName}}\",\n  \"email\": \"{{validEmail}}\",\n  \"password\": \"{{validPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Endpoint: POST /api/auth/register\nBody: nombre, email, password"
          }
        },
        {
          "name": "CP-002 Registro rechazado por correo invalido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Error de validacion', function () {",
                  "  pm.expect(json.errorCode).to.eql('VALIDATION_ERROR');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Usuario Correo Invalido\",\n  \"email\": \"{{invalidEmail}}\",\n  \"password\": \"{{validPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
